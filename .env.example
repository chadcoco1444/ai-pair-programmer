# Google Gemini (free tier key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=""
# Optional — override the Gemini model. Alternatives (free tier):
#   gemini-2.5-flash          (default — best quality/quota balance)
#   gemini-2.5-flash-lite     (highest quota, faster, lower quality)
#   gemini-2.0-flash          (previous default)
#   gemini-1.5-flash          (older, separate quota bucket)
#   gemini-1.5-flash-8b       (smallest, highest quota)
#   gemini-2.5-pro            (strongest, but much lower free quota)
GEMINI_MODEL=""

# Executor service
EXECUTOR_URL="http://localhost:4000"
