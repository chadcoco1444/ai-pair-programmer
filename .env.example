# Database
DATABASE_URL="postgresql://skill:skill_password@localhost:5433/skill_platform?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================================
# AI Tutor — multi-provider via Vercel AI SDK
# ============================================================
# Select one provider (default: anthropic). Only the matching API key
# needs to be set. Switch any time without touching code.
AI_PROVIDER="anthropic"  # anthropic | google | openai

# -- Anthropic (default, cheapest model is Haiku 4.5) -----------------
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
# Optional override. Model IDs:
#   claude-haiku-4-5-20251001  (default — cheapest)
#   claude-sonnet-4-6          (balanced quality/price)
#   claude-opus-4-7            (strongest, most expensive)
ANTHROPIC_MODEL=""

# -- Google Gemini (alternative) --------------------------------------
# Get key at https://aistudio.google.com/apikey
# AI SDK reads GOOGLE_GENERATIVE_AI_API_KEY; GEMINI_API_KEY also works
# as a legacy alias (auto-detected by this app).
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_API_KEY=""
# Optional override:
#   gemini-2.5-flash          (default)
#   gemini-2.5-flash-lite     (highest quota, lowest quality)
#   gemini-2.5-pro            (strongest, lower free quota)
GEMINI_MODEL=""

# -- OpenAI (alternative) --------------------------------------------
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Optional override (default: gpt-4o-mini)
OPENAI_MODEL=""

# Executor service
EXECUTOR_URL="http://localhost:4000"
